# Git ignore for AI Candlestick Trader

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Checkpoints & model weights ───────────────────────────────────────────────
checkpoints/
*.pt
*.pth
*.ckpt
*.pkl

# ── Data directories ──────────────────────────────────────────────────────────
data/images/
data/*.csv
uploads/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Optuna storage ────────────────────────────────────────────────────────────
*.db
optuna_*.sqlite3

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml
